# regenerated each run / local-only — never committed
# (but cache/macro IS committed: each file there is a PAID Claude call — persisting
#  them means a re-run reuses them for free instead of buying the same answer twice)
cache/*
!cache/macro/
__pycache__/
*.pyc
*.png
*.bak
*.output
server.log
macro_cron.log
macro_run.log
macro_manual_run.log
backfill.log
dashboard/site/
com.user.quant.dashboard.plist

# tracked (state that must persist across cloud runs):
#   *.jsonl  paper_state.json  target_tilts.json  all *.py  requirements.txt
